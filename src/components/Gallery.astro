---
// src/components/Gallery.astro
import imageUrlBuilder from "@sanity/image-url";
import { sanityClient } from "sanity:client";
import { Icon } from "astro-icon/components";

interface Props {
  galleryData: any;
}

const { galleryData } = Astro.props;

const builder = imageUrlBuilder(sanityClient);
function urlFor(source: any) {
  return builder.image(source);
}

const {
  subtitle = "Munkáink",
  title = "Kész munkák, valódi eredmények",
  description = "Minden kép valódi ügyfeleknél elvégzett munkát mutat be.",
  largeImage,
  smallImage,
  statsCard = {
    number: "500+",
    label: "Elvégzett munka",
    text: "Miskolcon és környékén, minden típusú bútor összeszerelése."
  }
} = galleryData || {};

// Cím formázása (utolsó két szó formázása)
const titleWords = title.split(' ');
const lastTwo = titleWords.splice(-2);
---

<section id="gallery" class="py-24 bg-cream-200">
  <div class="container mx-auto px-6">
    
    <div class="mb-12 fade-up">
      <div class="text-sm font-semibold uppercase tracking-widest mb-3 text-gold font-sans">
        {subtitle}
      </div>
      <h2 class="text-4xl md:text-5xl font-bold font-playfair text-walnut-800">
        {titleWords.join(' ')}{" "}
        <span class="italic text-amber">
          {lastTwo.join(' ')}
        </span>
      </h2>
      <p class="mt-4 text-lg max-w-xl text-earth-600">
        {description}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      
      {/* BAL OLDAL: Nagy kép */}
      <div class="fade-up fade-up-delay-1 rounded-2xl overflow-hidden group shadow-[0_8px_32px_oklch(0.28_0.05_42/0.15)]">
        <div class="relative overflow-hidden h-[250px] md:h-[360px]">
          {largeImage?.image && (
            <img
              src={urlFor(largeImage.image).width(800).height(800).auto('format').quality(80).url()}
              alt={largeImage.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          )}
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6" style="background: linear-gradient(to top, oklch(0.18 0.04 42 / 0.8) 0%, transparent 60%);">
            <div>
              <div class="font-bold text-lg font-playfair text-cream-50">
                {largeImage?.title}
              </div>
              <div class="text-sm text-gold">
                {largeImage?.location}
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* JOBB OLDAL: Rács (Kis kép + Kártya) */}
      <div class="grid grid-rows-2 gap-6">
        
        {/* Jobb felső: Kis kép */}
        <div class="fade-up fade-up-delay-2 rounded-2xl overflow-hidden group shadow-[0_8px_32px_oklch(0.28_0.05_42/0.15)]">
          <div class="relative overflow-hidden h-[200px] md:h-[168px]">
            {smallImage?.image && (
              <img
                src={urlFor(smallImage.image).width(600).height(400).auto('format').quality(80).url()}
                alt={smallImage.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            )}
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4" style="background: linear-gradient(to top, oklch(0.18 0.04 42 / 0.8) 0%, transparent 60%);">
              <div class="font-bold font-playfair text-cream-50">
                {smallImage?.title}
              </div>
            </div>
          </div>
        </div>

        {/* Jobb alsó: Statisztika Kártya */}
        <div class="fade-up fade-up-delay-3 rounded-2xl overflow-hidden flex flex-col justify-center p-8 h-[200px] md:h-[168px] bg-walnut-700 shadow-[0_8px_32px_oklch(0.28_0.05_42/0.15)]">
          <div class="text-4xl font-bold mb-2 font-playfair text-gold">
            {statsCard.number}
          </div>
          <div class="text-lg font-semibold mb-2 font-playfair text-cream-50">
            {statsCard.label}
          </div>
          <p class="text-sm text-sand-300">
            {statsCard.text}
          </p>
          <a
            href="https://www.facebook.com/butorosszeszerelesmiskolc"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 flex items-center gap-2 text-sm font-semibold transition-colors duration-200 text-gold"
          >
            <Icon name="lucide:facebook" class="w-4 h-4" />
            Több kép a Facebookon
            <Icon name="lucide:arrow-right" class="w-[14px] h-[14px]" />
          </a>
        </div>

      </div>
    </div>
  </div>
</section>