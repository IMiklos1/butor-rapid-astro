---
// src/components/Hero.astro
import imageUrlBuilder from "@sanity/image-url";
import { sanityClient } from "sanity:client";
import { Icon } from "astro-icon/components";

interface Props {
  heroData: any;
}

const { heroData } = Astro.props;

const builder = imageUrlBuilder(sanityClient);
function urlFor(source: any) {
  return builder.image(source);
}

const { 
  badgeText = "Bútor összeszerelés Miskolc",
  title = "Ön megveszi, Mi összerakjuk!", 
  subtitle = "Új bútort vettél, de nincs időd vagy türelmed összeszerelni? Gyorsan, precízen összeszerelek minden bútort.", 
  backgroundImage, 
  ctaText = "Hívjon most!",
  phoneNumber = "+36 30 814 0458",
  trustBadges = [
    { icon: "shield", text: "Megbízható" },
    { icon: "zap", text: "Gyors" },
    { icon: "award", text: "Szakértő" },
    { icon: "clock", text: "Mindig elérhető" }
  ],
  cardTitle = "Miért válasszon minket?",
  cardList = [
    "Minden márkájú bútor összeszerelése",
    "Akár hétvégén is elérhető",
    "Gyors, precíz, megbízható munka",
    "10+ év szakmai tapasztalat",
  ],
  customerCount = "1.600+"
} = heroData || {};

const bgUrl = backgroundImage ? urlFor(backgroundImage).width(1920).auto('format').quality(80).url() : "";

const titleParts = title.split(',');
const remainingTitle = titleParts[0] ? titleParts[0].trim() + ',' : '';

let secondToLastWord = '';
let lastWord = '';

if (titleParts.length > 1) {
  const afterComma = titleParts[1].trim(); 
  lastWord = afterComma.slice(-1);
  secondToLastWord = afterComma.slice(0, -1).trim();
}
---

<section id="about" class="relative min-h-screen flex items-center overflow-hidden bg-walnut-900">
  
  {/* ── Background Image & Overlay ── */}
  <div class="absolute inset-0">
    {bgUrl && <img src={bgUrl} alt="Bútor összeszerelés" class="w-full h-full object-cover opacity-35" />}
    <div class="absolute inset-0" style="background: linear-gradient(135deg, oklch(0.18 0.04 42 / 0.9) 0%, oklch(0.18 0.04 42 / 0.6) 50%, oklch(0.28 0.05 42 / 0.4) 100%);"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10 pt-24 pb-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      
      {/* ── LEFT: Text Content ── */}
      <div>
        {/* Kis címke */}
        <div class="fade-up inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold mb-6 bg-gold/15 border border-gold/40 text-gold font-sans">
          <Icon name="lucide:wrench" class="w-3 h-3" />
          {badgeText}
        </div>

        {/* Cím dinamikus formázása */}
        <h1 class="fade-up fade-up-delay-1 text-4xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6 font-playfair text-cream-50">
          {remainingTitle} <span class="italic text-gold">{secondToLastWord}</span>{lastWord}
        </h1>

        <p class="fade-up fade-up-delay-2 text-lg md:text-xl mb-8 leading-relaxed max-w-[520px] text-sand-200">
          {subtitle}
        </p>

        {/* Gombok */}
        <div class="fade-up fade-up-delay-3 flex flex-wrap gap-4 mb-10">
          <a href={`tel:${phoneNumber.replace(/\s+/g, '')}`} class="flex items-center gap-2 px-6 py-3.5 rounded font-semibold text-base transition-transform hover:scale-105 bg-gold text-walnut-900 font-sans shadow-[0_4px_20px_oklch(0.72_0.16_65/0.4)]">
            <Icon name="lucide:phone" class="w-4 h-4" />
            {ctaText}
          </a>
          <a href="#services" class="flex items-center gap-2 px-6 py-3.5 rounded font-semibold text-base transition-colors hover:bg-white/5 border-[1.5px] border-gold/50 text-sand-100 font-sans">
            Szolgáltatások
            <Icon name="lucide:chevron-down" class="w-4 h-4" />
          </a>
        </div>

        {/* Trust badges */}
        <div class="fade-up fade-up-delay-4 flex flex-wrap gap-6">
          {trustBadges.map((badge: any) => (
            <div class="flex items-center gap-1.5">
              <Icon name={`lucide:${badge.icon}`} class="w-3.5 h-3.5 text-gold" />
              <span class="text-sm text-sand-300">{badge.text}</span>
            </div>
          ))}
        </div>
      </div>

      {/* ── RIGHT: Info Card ── */}
      <div class="hidden lg:block fade-up fade-up-delay-2">
        <div class="rounded-2xl p-8 bg-cream-50/8 border border-gold/25 backdrop-blur-lg">
          
          <h3 class="text-xl font-bold mb-6 font-playfair text-cream-50">
            {cardTitle}
          </h3>
          
          <div class="space-y-4">
            {cardList.map((item: string) => (
              <div class="flex items-start gap-3">
                <Icon name="lucide:check-circle-2" class="w-[18px] h-[18px] mt-0.5 shrink-0 text-gold" />
                <span class="text-sm leading-relaxed text-sand-200">
                  {item}
                </span>
              </div>
            ))}
          </div>

          <div class="mt-8 pt-6 border-t border-gold/20">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full flex items-center justify-center text-lg font-bold bg-gold text-walnut-900 font-playfair">
                BR
              </div>
              <div>
                <div class="font-semibold text-sm text-cream-50">Bútor Rapid</div>
                <div class="text-xs text-gold">{customerCount} elégedett ügyfél</div>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>

  {/* Scroll indicator (pattogó nyíl) */}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <Icon name="lucide:chevron-down" class="w-6 h-6 text-gold" />
  </div>
</section>