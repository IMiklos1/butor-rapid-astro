---
// src/components/Testimonials.astro
import { Icon } from "astro-icon/components";

interface Props {
  testimonials: any[];
}

const { testimonials } = Astro.props;
---

<section
    id="testimonials"
    class="py-24 bg-[#F5F0E8] border-t border-[#3D2B1F]/10"
>
    <div class="container mx-auto px-6">
        <div class="mb-12 fade-up">
            <div
                class="text-sm font-semibold uppercase tracking-widest mb-3 text-[#D4820A] font-source"
            >
                Vélemények
            </div>
            <h2
                class="text-4xl md:text-5xl font-bold font-playfair text-[#3D2B1F]"
            >
                Mit mondanak <span class="italic text-[#8B5E3C]"
                    >ügyfeleink</span
                >?
            </h2>
        </div>

        {/* Vélemény kártyák rácsa */}
        <div class="grid md:grid-cols-3 gap-6">
            {
                testimonials.map((t: any, i: number) => (
                    <div
                        class="fade-up rounded-xl p-7 bg-white border border-[#3D2B1F]/10 shadow-sm"
                        style={`transition-delay: ${i * 100}ms`}
                    >
                        {/* Csillagok rajzolása */}
                        <div class="flex gap-1 mb-4 text-[#D4820A]">
                            {/* Itt csinálunk egy X hosszú tömböt a rating alapján, majd végigiterálunk rajta */}
                            {Array.from({ length: t.rating || 5 }).map(() => (
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                            ))}
                        </div>

                        <p class="text-base leading-relaxed mb-6 italic text-[#3D2B1F]/70 font-playfair">
                            "{t.text}"
                        </p>

                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold bg-[#F5F0E8] text-[#3D2B1F] font-playfair border border-[#3D2B1F]/10">
                                {t.name.charAt(0)}
                            </div>
                            <div>
                                <div class="font-semibold text-sm text-[#3D2B1F]">
                                    {t.name}
                                </div>
                                <div class="text-xs flex items-center gap-1 text-[#3D2B1F]/60">
                                    <Icon
                                        name="lucide:map-pin"
                                        class="w-3 h-3"
                                    />
                                    {t.location}
                                </div>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>

        {/* Facebook Social Proof Kártya */}
        <div
            class="fade-up mt-10 p-6 rounded-xl flex flex-col sm:flex-row items-center justify-between gap-4 bg-[#E8E2D8] border border-[#3D2B1F]/10"
            style="transition-delay: 400ms;"
        >
            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-full flex items-center justify-center bg-[#1877F2] text-white"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="w-6 h-6"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                </div>
                <div>
                    <div class="font-bold font-playfair text-[#3D2B1F]">
                        1.600+ követő a Facebookon
                    </div>
                    <div class="text-sm text-[#3D2B1F]/70">
                        Kövessen minket és láthatja legújabb munkáinkat!
                    </div>
                </div>
            </div>
            <a
                href="https://www.facebook.com/butorosszeszerelesmiskolc"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-5 py-2.5 rounded font-semibold text-sm whitespace-nowrap bg-[#1877F2] text-white hover:bg-[#166fe5] transition-colors"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="w-4 h-4"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                Facebook oldal
            </a>
        </div>
    </div>
</section>